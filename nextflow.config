executor {
    name = 'local'
    cpus = 12
    memory = '8 GB'
}

params {
    outdir = 'results'
    links_file = 'data/ZINC-downloader-3D-pdbqt.gz.uri'

    // --- 2D (SMILES) options ---
    chunk_size = 200

    // --- 3D (PDBQT) options ---
    use3d_downloader = true

    // Downloader Options
    skip_download = true
    smiles_file = '' // use --smiles_file for dynamic usage
    pdbqt_file = '' // use --pdbqt_file for dynamic usage

    // Docking Options
    receptor = 'data/hif2a_temiz.pdbqt'
    override = false // overwrites if same file docked before otherwise skips.
    exhaustiveness = 8
    center_x = -13.02726936340332
    center_y = -22.765233993530273
    center_z = 21.719926834106445
    size_x = 20.0
    size_y = 20.0
    size_z = 20.0
    num_modes = 9
    energy_range = 3.0
}

process {
    withName: DOWNLOAD_SMILES {
        maxForks = 1        // Only one download at a time
        maxRetries = 5      // Retry if we get a 503
        errorStrategy = 'retry'
    }
    withName: DOWNLOAD_PDBQT_AND_UNZIP {
        maxForks = 1        // Only one download at a time
        maxRetries = 5      // Retry if we get a 503
        errorStrategy = 'retry'
    }
    withName: OBABEL_CONVERT_SMILES {
        cpus = 4
        maxForks = 8
    }

    withName: DOCKING {
        maxForks = 8        // Use 8 cores for the actual math
    }
}

env {
    OMP_NUM_THREADS = '2'
    OPENBLAS_NUM_THREADS = '2'
    MKL_NUM_THREADS = '2'
}
