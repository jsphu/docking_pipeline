docker {
    enabled = true
}
params {
    outdir = 'results'
    skip_download = true
    receptor = 'data/protein_6NJS_prepared.pdbqt'
    override = false // overwrites if same file docked before otherwise skips.
    exhaustiveness = 8
    center_x = 13.028
    center_y = 55.637
    center_z = 0.250
    size_x = 10.0
    size_y = 10.0
    size_z = 10.0
    num_modes = 9
    energy_range = 3.0
    thread_size = 1000
    collate_size = 3750
    use_gpu = true
}
process {
    withName: DOCKING_GPU {
        container = "ghcr.io/jsphu/docking_pipeline/quickvina-gpu:latest"
        maxForks = 1
      }
  }
